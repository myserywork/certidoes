# ─── Redis (mesmo para TODAS as maquinas) ─────────────────
REDIS_URL=redis://default:tjp5bDfy2uU4P7RNKroDoxk0QeiyeXNX@redis-10074.c256.us-east-1-2.ec2.cloud.redislabs.com:10074

# ─── Worker (ajustar por maquina) ──────────────────────────
# MAX_CHROME depende da RAM:
#   64GB  -> MAX_CHROME=12
#   128GB -> MAX_CHROME=25
#   256GB -> MAX_CHROME=50
MAX_CHROME=6

# Nome unico por maquina (aparece no dashboard)
WORKER_ID=worker-maquina1

# Porta da API (so precisa na maquina que roda a API)
API_PORT=8000

# 2Captcha (opcional - melhora taxa de sucesso de 60% para 95%)
# Sem chave = usa solver local (Whisper/CLIP/stealth)
# Com chave = usa 2captcha como primario, local como fallback
CAPTCHA_API_KEY=
